{
  "name": "workspacewire",
  "version": "0.1.0",
  "description": "Local-first Google Workspace operation planner for agents.",
  "type": "module",
  "bin": { "workspacewire": "./src/cli.js" },
  "main": "./src/index.js",
  "exports": { ".": "./src/index.js" },
  "files": ["src", "tests/fixtures", "docs", "examples", "README.md", "LICENSE"],
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "bash scripts/package-smoke.sh",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke && node scripts/releasebox.mjs check .",
    "release:notes": "node scripts/releasebox.mjs notes"
  },
  "keywords": ["google-workspace", "planner", "dry-run", "oauth", "agents", "cli"],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": { "node": ">=20" }
}
